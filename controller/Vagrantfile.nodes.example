# -*- mode: ruby -*-
# vi: set ft=ruby :

# All Vagrant configuration is done below. The "2" in Vagrant.configure
# configures the configuration version (we support older styles for
# backwards compatibility). Please don't change it unless you know what
# you're doing.
Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"
  config.vm.box_version = "20240821.0.1"
  # node 1 master
  config.vm.define "node-1" do |node_1|
    node_1.vm.hostname = "node-1"
    node_1.vm.network "public_network", ip: "192.168.33.15"
    #node_1.vm.network "private_network", type: "dhcp"
  end

  # node 2 slave
  config.vm.define "node-2" do |node_2|
    node_2.vm.hostname = "node-2"
    node_2.vm.network "public_network", ip: "192.168.33.16"
    #node_2.vm.network "private_network", type: "dhcp"
  end

  # config.vm.network "private_network", ip: "192.168.33.10"


  # Enable public network
  # config.vm.network "public_network"

  #config.vm.provider :managed do |managed, override|
  #  managed.server = "192.168.33.10"
  #  # configure the ssh connection for remote deployment
  #  config.ssh.username = "username"
  #  config.ssh.port = 2222
  #end
  # config.vm.synced_folder "../data", "/vagrant_data"
  config.vm.synced_folder ".", "/vagrant", type: "rsync"

  # config.vm.synced_folder ".", "/vagrant", disabled: true

  # provider-specific virtualbox
  config.vm.provider "virtualbox" do |vb|
  #  # Name
  #  vb.name = "kube-node1"

  #  # RAM Memory & CPU
    vb.memory = "2048"
    vb.cpus = 1
  end
  # config.vm.provider "virtualbox" do |vb|
  #   # Display the VirtualBox GUI when booting the machine
  #   vb.gui = true
  #
  #   # Customize the amount of memory on the VM:
  #   vb.memory = "1024"
  # end
  #
  # config.vm.provision "shell", inline: <<-SHELL
  #   apt-get update
  #   apt-get install -y apache2
  # SHELL
end
